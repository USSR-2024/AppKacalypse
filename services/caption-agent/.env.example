# Секреты GPU-агента. Реальный .env — только на 158, в git НЕ коммитим.
# Значения берутся из backend/.env на 158 (должны совпадать!):
#   LIVEKIT_API_KEY/SECRET — те же, что в livekit.yaml
#   WORKER_TOKEN           — гейт воркер-роутов бэкенда
#   HF_TOKEN               — /root/transcribe/hf_token (диаризация pyannote)
LIVEKIT_API_KEY=<как в backend/.env>
LIVEKIT_API_SECRET=<как в backend/.env>
WORKER_TOKEN=<как в backend/.env>
HF_TOKEN=<содержимое /root/transcribe/hf_token>
