# Backend AppKacalypse
PORT=8081
DATABASE_URL=postgres://task_dispatcher:CHANGE_ME@postgres:5432/task_dispatcher

# JWT — подписывает сессии приложения
JWT_SECRET=CHANGE_ME
JWT_TTL=30d

# Telegram — токен бота от @BotFather (auth + интейк)
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Свежесть Telegram Login (сек): подпись старше — отклоняем
TELEGRAM_AUTH_MAX_AGE=86400

# LLM Gateway (уже работает)
GATEWAY_URL=http://llm-gateway:8000

# Web Push (VAPID) — генерим: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@baassist.ru
