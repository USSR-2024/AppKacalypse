# Caddy — HTTPS и reverse proxy.
# Домены и email берутся из окружения (см. .env / docker-compose).
{
	email {$ACME_EMAIL}
}

# Основной домен appka.space (мульти-тенант, путь /<slug>) + старый домен на
# переходный период (старые установленные PWA продолжают работать).
appka.space, www.appka.space, {$DOMAIN_TASKS} {
	encode gzip
	# Наше приложение: /api/* → бэкенд, остальное → фронт (Next).
	handle /api/* {
		reverse_proxy backend:8081
	}
	handle {
		reverse_proxy frontend:3000
	}
}

# Видеовстречи: сигналинг LiveKit (wss). LiveKit крутится в host-network на :7880,
# Caddy достаёт его через host-gateway (в docker-compose.yml у caddy добавлено
# extra_hosts: "host.docker.internal:host-gateway"). Активировать после DNS
# meet.appka.space → 158.255.0.82. Медиа (UDP 50000-50200 / TURN 3478) идёт мимо Caddy.
meet.appka.space {
	reverse_proxy host.docker.internal:7880
}

# ONLYOFFICE Document Server: браузер грузит api.js и держит WebSocket совместного
# редактирования напрямую с DS (минуя backend). DS — контейнер akc-docs в этой же
# сети, слушает :80. Активировать ПОСЛЕ DNS docs.appka.space → 158.255.0.82.
docs.appka.space {
	reverse_proxy akc-docs:80
}

# Локально / без домена — отдаём по IP с internal-сертификатом.
# Закомментируй блок выше и раскомментируй ниже для dev:
