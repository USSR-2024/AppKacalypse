# ONLYOFFICE Document Server — окружение контейнера akc-docs.
# Реальный файл infra/ds.env НЕ в git (секрет). Скопировать в infra/ds.env на 158
# и подставить JWT_SECRET, СОВПАДАЮЩИЙ с DS_JWT_SECRET в backend/.env.
JWT_ENABLED=true
JWT_SECRET=<32+ случайных байт, тот же, что DS_JWT_SECRET в backend/.env>
JWT_HEADER=Authorization
JWT_IN_BODY=true
WOPI_ENABLED=false
